# Redis — points to the Docker redis service
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev123

# MongoDB (service hostname: mongodb)
MONGODB_URI=mongodb://admin:dev123@mongodb:27017/interaone?authSource=admin

# Email provider
EMAIL_PROVIDER=resend

# Resend
RESEND_API_KEY=

# Email sender identity
EMAIL_FROM_NAME=InteraOne
EMAIL_FROM_EMAIL=noreply@InteraOne.app

WORKER_CONCURRENCY=5
